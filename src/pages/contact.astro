---
import BaseLayout from '../layouts/BaseLayout.astro';
import t from '../content/text';
---
<BaseLayout title={t.contact.title} description={t.contact.description} pagePath="/contact">
  <h1 class="text-sm mb-2 text-(--color-text-dim)">{t.contact.heading}</h1>
  <p class="text-sm text-(--color-text-dim) mb-8">{t.contact.subtitle}</p>

  <div class="prose text-sm leading-relaxed space-y-6 text-(--color-text)">
    <div class="border border-(--color-border) p-6 bg-(--color-bg-card) card space-y-3">
      <div class="flex items-center gap-3">
        <span class="text-(--color-text-dim) w-20">Email</span>
        <a href={`mailto:${t.links.email}`} class="text-(--color-accent)">{t.links.email}</a>
      </div>
      <div class="flex items-center gap-3">
        <span class="text-(--color-text-dim) w-20">Telegram</span>
        <a href={t.links.telegramUrl} target="_blank" rel="noopener" class="text-(--color-accent)">{t.links.telegram}</a>
      </div>
      <div class="flex items-center gap-3">
        <span class="text-(--color-text-dim) w-20">hh.ru</span>
        <span class="text-(--color-text-dim)">профиль (скоро)</span>
      </div>
      <div class="flex items-center gap-3">
        <span class="text-(--color-text-dim) w-20">LinkedIn</span>
        <span class="text-(--color-text-dim)">профиль (скоро)</span>
      </div>
      <div class="flex items-center gap-3">
        <span class="text-(--color-text-dim) w-20">GitHub</span>
        <a href={t.links.githubUrl} target="_blank" rel="noopener" class="text-(--color-accent)">{t.links.github}</a>
      </div>
    </div>

    <h2 class="text-sm mt-8 mb-4 text-(--color-text-dim)">{t.contact.offersHeading}</h2>

    <ul class="space-y-3 list-none p-0">
      <li class="border-l-2 border-(--color-accent) pl-4">{t.contact.offer1}</li>
      <li class="border-l-2 border-(--color-accent) pl-4">{t.contact.offer2}</li>
      <li class="border-l-2 border-(--color-accent) pl-4">{t.contact.offer3}</li>
    </ul>
  </div>
</BaseLayout>
