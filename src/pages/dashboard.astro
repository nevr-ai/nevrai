---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Dashboard — nevrai" description="Manage your API keys and monitor usage." pagePath="/dashboard">

<!-- Login state -->
<div id="app-login" style="display:none;">
  <div class="flex flex-col items-center justify-center py-20">
    <h2 class="text-2xl font-semibold mb-2 text-(--color-text)">nevrai Dashboard</h2>
    <p class="text-(--color-text-dim) mb-8">Sign in to manage your API keys</p>
    <a
      id="google-login-btn"
      href="https://api.nevrai.com/v1/auth/google"
      class="inline-flex items-center gap-3 px-6 py-3 rounded-lg bg-white text-[#3c4043] text-sm font-medium shadow hover:shadow-md transition-shadow no-underline"
    >
      <svg width="18" height="18" viewBox="0 0 48 48">
        <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
        <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
        <path fill="#FBBC05" d="M10.53 28.59A14.5 14.5 0 019.5 24c0-1.59.28-3.14.76-4.59l-7.98-6.19A23.99 23.99 0 000 24c0 3.77.9 7.35 2.56 10.53l7.97-5.94z"/>
        <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 5.94C6.51 42.62 14.62 48 24 48z"/>
      </svg>
      Continue with Google
    </a>
    <p class="mt-6 text-xs text-(--color-text-dim)">
      By signing in you agree to our
      <a href="/terms" class="text-(--color-accent) hover:underline">Terms of Service</a>
    </p>
  </div>
</div>

<!-- Auth error -->
<div id="app-error" style="display:none;" class="flex flex-col items-center justify-center py-20">
  <p class="text-red-400 text-sm mb-4" id="error-message"></p>
  <a
    href="https://api.nevrai.com/v1/auth/google"
    class="px-4 py-2 rounded bg-(--color-accent) text-(--color-bg) text-sm font-semibold hover:bg-(--color-accent-hover) transition-colors no-underline"
  >
    Try again
  </a>
</div>

<!-- Dashboard state -->
<div id="app-dashboard" style="display:none;">
  <!-- Header -->
  <div class="flex items-center justify-between mb-8">
    <h2 class="text-xl font-semibold text-(--color-text)">Dashboard</h2>
    <div class="relative">
      <button
        id="user-menu-btn"
        class="flex items-center gap-2 px-3 py-1.5 rounded border border-(--color-border) text-sm text-(--color-text-dim) hover:text-(--color-text) hover:border-(--color-accent) transition-colors cursor-pointer"
      >
        <span id="user-email"></span>
        <svg width="12" height="12" viewBox="0 0 12 12" fill="currentColor"><path d="M3 5l3 3 3-3"/></svg>
      </button>
      <div
        id="user-dropdown"
        style="display:none;"
        class="absolute right-0 mt-1 w-36 rounded border border-(--color-border) bg-(--color-surface) shadow-lg z-10"
      >
        <button
          id="logout-btn"
          class="w-full text-left px-4 py-2 text-sm text-(--color-text-dim) hover:text-(--color-text) hover:bg-(--color-bg) transition-colors cursor-pointer rounded"
        >
          Log out
        </button>
      </div>
    </div>
  </div>

  <!-- API Keys section -->
  <section class="mb-10">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-lg font-semibold text-(--color-text)">API Keys</h3>
      <button
        id="create-key-btn"
        class="px-3 py-1.5 rounded bg-(--color-accent) text-(--color-bg) text-sm font-semibold hover:bg-(--color-accent-hover) transition-colors cursor-pointer"
      >
        + Create key
      </button>
    </div>

    <!-- New key form (hidden) -->
    <div id="new-key-form" style="display:none;" class="mb-4 p-4 rounded-lg border border-(--color-border) bg-(--color-surface)">
      <label class="block text-sm text-(--color-text-dim) mb-2">Key name</label>
      <div class="flex gap-3">
        <input
          type="text"
          id="new-key-name"
          placeholder="e.g. production, staging"
          class="flex-1 px-3 py-2 rounded border border-(--color-border) bg-(--color-bg) text-(--color-text) text-sm focus:outline-none focus:border-(--color-accent)"
        />
        <button
          id="confirm-create-btn"
          class="px-4 py-2 rounded bg-(--color-accent) text-(--color-bg) text-sm font-semibold hover:bg-(--color-accent-hover) transition-colors cursor-pointer"
        >
          Create
        </button>
        <button
          id="cancel-create-btn"
          class="px-4 py-2 rounded border border-(--color-border) text-sm text-(--color-text-dim) hover:text-(--color-text) transition-colors cursor-pointer"
        >
          Cancel
        </button>
      </div>
    </div>

    <!-- Newly created key display (hidden) -->
    <div id="new-key-display" style="display:none;" class="mb-4 p-4 rounded-lg border-2 border-(--color-accent) bg-(--color-surface)">
      <p class="text-sm text-(--color-accent) font-semibold mb-2">Key created! Copy it now — you won't see it again.</p>
      <div class="flex gap-2 items-center">
        <code id="new-key-value" class="flex-1 text-sm break-all text-(--color-text) bg-(--color-bg) px-3 py-2 rounded"></code>
        <button
          id="copy-new-key-btn"
          class="px-3 py-1.5 rounded border border-(--color-border) text-sm text-(--color-text-dim) hover:text-(--color-accent) transition-colors cursor-pointer"
        >
          Copy
        </button>
      </div>
    </div>

    <!-- Keys list -->
    <div id="keys-list" class="space-y-3">
      <p class="text-sm text-(--color-text-dim)">Loading...</p>
    </div>
  </section>

  <!-- Usage section -->
  <section class="mb-10">
    <h3 class="text-lg font-semibold text-(--color-text) mb-4">Usage this month</h3>
    <div id="usage-data">
      <p class="text-sm text-(--color-text-dim)">Loading...</p>
    </div>
  </section>

  <!-- Quick Start section -->
  <section>
    <h3 class="text-lg font-semibold text-(--color-text) mb-4">Quick Start</h3>
    <div class="relative rounded-lg border border-(--color-border) bg-(--color-surface) p-4">
      <button
        id="copy-curl-btn"
        class="absolute top-3 right-3 px-2 py-1 rounded text-xs text-(--color-text-dim) hover:text-(--color-accent) border border-(--color-border) transition-colors cursor-pointer"
      >
        Copy
      </button>
      <pre class="text-sm text-(--color-text) overflow-x-auto leading-relaxed"><code id="curl-example">curl -X POST https://api.nevrai.com/v1/chat/completions \
  -H "Authorization: Bearer YOUR_API_KEY" \
  -H "Content-Type: application/json" \
  -d '{"messages":[{"role":"user","content":"Hello"}]}'</code></pre>
    </div>
  </section>
</div>

<script is:inline>
(function() {
  var API = 'https://api.nevrai.com';
  var loginEl = document.getElementById('app-login');
  var dashEl = document.getElementById('app-dashboard');
  var errorEl = document.getElementById('app-error');

  // Handle OAuth callback: exchange code for session
  var params = new URLSearchParams(window.location.search);
  var code = params.get('code');
  var authError = params.get('auth_error');

  if (authError) {
    showError(decodeError(authError));
    cleanUrl();
  } else if (code) {
    exchangeCode(code);
    cleanUrl();
  } else {
    var session = localStorage.getItem('nevrai_session');
    if (session) {
      showDashboard(session);
    } else {
      showLogin();
    }
  }

  function decodeError(err) {
    var map = {
      access_denied: 'You cancelled the sign-in.',
      token_exchange_failed: 'Authentication failed. Please try again.',
      invalid_state: 'Session expired. Please try again.',
      missing_params: 'Invalid callback. Please try again.',
      no_id_token: 'Could not get your email from Google.',
      invalid_token: 'Could not verify your identity.',
    };
    return map[err] || 'Authentication error: ' + err;
  }

  function cleanUrl() {
    if (window.history.replaceState) {
      window.history.replaceState({}, '', window.location.pathname);
    }
  }

  async function exchangeCode(code) {
    try {
      var res = await fetch(API + '/v1/auth/exchange', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ code: code }),
      });
      if (!res.ok) {
        showError('Login failed. Please try again.');
        return;
      }
      var data = await res.json();
      localStorage.setItem('nevrai_session', data.session);
      if (data.email) localStorage.setItem('nevrai_email', data.email);
      showDashboard(data.session);
    } catch (e) {
      showError('Network error. Please try again.');
    }
  }

  function showLogin() {
    loginEl.style.display = '';
    dashEl.style.display = 'none';
    errorEl.style.display = 'none';
  }

  function showError(msg) {
    loginEl.style.display = 'none';
    dashEl.style.display = 'none';
    errorEl.style.display = '';
    document.getElementById('error-message').textContent = msg;
  }

  function showDashboard(session) {
    loginEl.style.display = 'none';
    dashEl.style.display = '';
    errorEl.style.display = 'none';

    var email = localStorage.getItem('nevrai_email') || '';
    document.getElementById('user-email').textContent = email;

    loadKeys(session);
    loadUsage(session);
    updateCurlExample();
  }

  function logout() {
    localStorage.removeItem('nevrai_session');
    localStorage.removeItem('nevrai_email');
    showLogin();
  }

  // User dropdown
  document.getElementById('user-menu-btn').addEventListener('click', function(e) {
    e.stopPropagation();
    var dd = document.getElementById('user-dropdown');
    dd.style.display = dd.style.display === 'none' ? '' : 'none';
  });

  document.addEventListener('click', function() {
    document.getElementById('user-dropdown').style.display = 'none';
  });

  document.getElementById('logout-btn').addEventListener('click', logout);

  // Create key
  document.getElementById('create-key-btn').addEventListener('click', function() {
    document.getElementById('new-key-form').style.display = '';
    document.getElementById('new-key-display').style.display = 'none';
    document.getElementById('new-key-name').value = '';
    document.getElementById('new-key-name').focus();
  });

  document.getElementById('cancel-create-btn').addEventListener('click', function() {
    document.getElementById('new-key-form').style.display = 'none';
  });

  document.getElementById('new-key-name').addEventListener('keydown', function(e) {
    if (e.key === 'Enter') document.getElementById('confirm-create-btn').click();
  });

  document.getElementById('confirm-create-btn').addEventListener('click', async function() {
    var name = document.getElementById('new-key-name').value.trim();
    if (!name) return;
    var session = localStorage.getItem('nevrai_session');
    var btn = this;
    btn.disabled = true;
    btn.textContent = 'Creating...';
    try {
      var res = await fetch(API + '/v1/keys', {
        method: 'POST',
        headers: { 'Authorization': 'Bearer ' + session, 'Content-Type': 'application/json' },
        body: JSON.stringify({ name: name }),
      });
      if (res.status === 401) { logout(); return; }
      var data = await res.json();
      document.getElementById('new-key-form').style.display = 'none';
      document.getElementById('new-key-name').value = '';
      if (data.key) {
        document.getElementById('new-key-value').textContent = data.key;
        document.getElementById('new-key-display').style.display = '';
      }
      loadKeys(session);
      updateCurlExample();
    } catch (e) {
      console.error('Create key error:', e);
    }
    btn.disabled = false;
    btn.textContent = 'Create';
  });

  document.getElementById('copy-new-key-btn').addEventListener('click', function() {
    var val = document.getElementById('new-key-value').textContent;
    copyText(val, this);
  });

  // Copy curl
  document.getElementById('copy-curl-btn').addEventListener('click', function() {
    var val = document.getElementById('curl-example').textContent;
    copyText(val, this);
  });

  function copyText(text, btn) {
    navigator.clipboard.writeText(text).then(function() {
      var orig = btn.textContent;
      btn.textContent = 'Copied!';
      setTimeout(function() { btn.textContent = orig; }, 2000);
    });
  }

  // Load keys
  var cachedKeys = [];
  async function loadKeys(session) {
    var container = document.getElementById('keys-list');
    try {
      var res = await fetch(API + '/v1/keys', {
        headers: { 'Authorization': 'Bearer ' + session },
      });
      if (res.status === 401) { logout(); return; }
      var data = await res.json();
      var keys = data.keys || [];
      cachedKeys = keys;

      if (keys.length === 0) {
        container.innerHTML = '<p class="text-sm text-(--color-text-dim)">No API keys yet. Create one to get started.</p>';
        return;
      }

      container.innerHTML = keys.map(function(k) {
        var prefix = esc(k.prefix || k.key_id || k.id);
        var created = k.created_at ? formatDate(k.created_at) : '';
        var lastUsed = k.last_used_at ? timeAgo(k.last_used_at) : 'Never used';

        return '<div class="p-4 rounded-lg border border-(--color-border) bg-(--color-surface)">' +
          '<div class="flex items-center justify-between mb-2">' +
            '<span class="text-sm font-semibold text-(--color-text)">' + esc(k.name) + '</span>' +
            '<div class="flex items-center gap-2">' +
              '<button onclick="copyKey(\'' + esc(prefix) + '...\')" class="px-2 py-1 rounded text-xs text-(--color-text-dim) hover:text-(--color-accent) border border-(--color-border) transition-colors cursor-pointer">Copy prefix</button>' +
              '<button onclick="deleteKey(\'' + esc(k.key_id) + '\')" class="px-2 py-1 rounded text-xs text-(--color-text-dim) hover:text-red-400 border border-(--color-border) transition-colors cursor-pointer">Delete</button>' +
            '</div>' +
          '</div>' +
          '<div class="flex items-center gap-4 text-xs text-(--color-text-dim)">' +
            '<code class="text-(--color-text-dim)">' + prefix + '...</code>' +
            '<span>Created ' + created + '</span>' +
            '<span>' + lastUsed + '</span>' +
          '</div>' +
        '</div>';
      }).join('');
    } catch (e) {
      container.innerHTML = '<p class="text-sm text-red-400">Failed to load keys.</p>';
    }
  }

  window.copyKey = function(text) {
    navigator.clipboard.writeText(text);
  };

  window.deleteKey = async function(keyId) {
    if (!confirm('Delete this API key? This cannot be undone.')) return;
    var session = localStorage.getItem('nevrai_session');
    try {
      var res = await fetch(API + '/v1/keys/' + keyId, {
        method: 'DELETE',
        headers: { 'Authorization': 'Bearer ' + session },
      });
      if (res.status === 401) { logout(); return; }
      loadKeys(session);
      updateCurlExample();
    } catch (e) {
      console.error('Delete key error:', e);
    }
  };

  // Load usage
  async function loadUsage(session) {
    var container = document.getElementById('usage-data');
    try {
      var res = await fetch(API + '/v1/usage', {
        headers: { 'Authorization': 'Bearer ' + session },
      });
      if (res.status === 401) { logout(); return; }
      var data = await res.json();
      var usage = data.usage || data;
      var limits = data.limits || {};

      if (usage.total !== undefined) {
        var limit = limits.monthly || 1000;
        var used = usage.total || 0;
        var pct = Math.round((used / limit) * 100);
        var barColor = pct > 90 ? '#ef4444' : pct > 70 ? '#eab308' : 'var(--color-accent)';
        var tier = data.tier || 'Free';

        container.innerHTML =
          '<div class="p-4 rounded-lg border border-(--color-border) bg-(--color-surface)">' +
            '<div class="flex justify-between text-sm mb-2">' +
              '<span class="text-(--color-text-dim)">Requests</span>' +
              '<span class="text-(--color-text) font-semibold">' + used.toLocaleString() + ' / ' + limit.toLocaleString() + '</span>' +
            '</div>' +
            '<div class="w-full h-2 rounded-full bg-(--color-bg) overflow-hidden">' +
              '<div class="h-full rounded-full transition-all" style="width:' + Math.min(pct, 100) + '%;background:' + barColor + '"></div>' +
            '</div>' +
            '<p class="mt-3 text-sm text-(--color-text-dim)">Plan: <span class="text-(--color-text) font-semibold capitalize">' + esc(tier) + '</span></p>' +
          '</div>';
      } else {
        container.innerHTML = '<p class="text-sm text-(--color-text-dim)">No usage data yet.</p>';
      }
    } catch (e) {
      container.innerHTML = '<p class="text-sm text-red-400">Failed to load usage data.</p>';
    }
  }

  function updateCurlExample() {
    var keyText = 'YOUR_API_KEY';
    if (cachedKeys.length > 0) {
      keyText = (cachedKeys[0].prefix || cachedKeys[0].key_id || 'nvr_live_xxx') + '...';
    }
    var curlEl = document.getElementById('curl-example');
    if (curlEl) {
      curlEl.textContent =
        'curl -X POST https://api.nevrai.com/v1/chat/completions \\\n' +
        '  -H "Authorization: Bearer ' + keyText + '" \\\n' +
        '  -H "Content-Type: application/json" \\\n' +
        '  -d \'{"messages":[{"role":"user","content":"Hello"}]}\'';
    }
  }

  function formatDate(iso) {
    try {
      var d = new Date(iso);
      var months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
      return months[d.getMonth()] + ' ' + d.getDate();
    } catch (e) {
      return '';
    }
  }

  function timeAgo(iso) {
    try {
      var diff = Date.now() - new Date(iso).getTime();
      var mins = Math.floor(diff / 60000);
      if (mins < 1) return 'Just now';
      if (mins < 60) return mins + 'm ago';
      var hrs = Math.floor(mins / 60);
      if (hrs < 24) return hrs + 'h ago';
      var days = Math.floor(hrs / 24);
      return days + 'd ago';
    } catch (e) {
      return '';
    }
  }

  function esc(s) {
    if (!s) return '';
    var d = document.createElement('div');
    d.textContent = s;
    return d.innerHTML;
  }
})();
</script>

</BaseLayout>
