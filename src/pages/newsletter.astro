---
import BaseLayout from '../layouts/BaseLayout.astro';
import Newsletter from '../components/Newsletter.astro';
---
<BaseLayout title="Newsletter — nevrai" description="Follow the build. One email when I ship something new.">
  <h1 class="text-sm mb-2 text-(--color-text-dim)">## Newsletter</h1>

  <div class="space-y-6">
    <div class="text-sm text-(--color-text) leading-relaxed space-y-4">
      <p>Follow the build.</p>
      <p>
        I send one email when I ship something new — a product launch, a meaningful update,
        or a blog post about how I build things. No drip campaigns, no growth hacks, no "valuable content" filler.
      </p>
      <p>Unsubscribe anytime. I respect your inbox more than most.</p>
    </div>

    <Newsletter />

    <div class="text-sm text-(--color-text-dim) space-y-2">
      <p>Previous topics:</p>
      <ul class="list-none p-0 space-y-1">
        <li class="font-mono text-xs">&gt; How I built 6 products in 3 weeks</li>
        <li class="font-mono text-xs">&gt; The $15/month infrastructure stack</li>
        <li class="font-mono text-xs">&gt; Factory OS: my AI agent orchestrator</li>
      </ul>
    </div>
  </div>
</BaseLayout>
