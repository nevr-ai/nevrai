---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import BlogPostCard from '../components/BlogPostCard.astro';
import Newsletter from '../components/Newsletter.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const products = [
  {
    name: 'CoffeeBot',
    tagline: 'AI coffee recommendation quiz',
    url: 'https://coffeebot.app',
    status: 'LIVE' as const,
    stack: ['Astro', 'Tailwind', 'Groq'],
  },
  {
    name: 'InkCloak',
    tagline: 'AI text detector & humanizer',
    url: 'https://inkcloak.com',
    status: 'LAUNCHING' as const,
    stack: ['Next.js', 'DeBERTa', 'RunPod'],
  },
  {
    name: 'AICPO',
    tagline: 'Cursor for product research',
    url: 'https://aicpo.app',
    status: 'BUILDING' as const,
    stack: ['Rails', 'SQLite', 'Groq'],
  },
  {
    name: 'Scrutly',
    tagline: 'Free AI text detector',
    url: 'https://scrutly.ai',
    status: 'PLANNED' as const,
    stack: ['Astro', 'DeBERTa'],
  },
  {
    name: 'Tool Sites',
    tagline: '199 programmatic SEO pages',
    status: 'LIVE' as const,
    stack: ['Astro', 'Tailwind', 'MDX'],
    metric: '199 pages across 5 domains',
  },
  {
    name: 'OpenClaw Finance',
    tagline: 'AI finance agent factory',
    status: 'BUILT' as const,
    stack: ['Python', 'DeepSeek R1', 'Docker'],
  },
];
---
<BaseLayout title="nevrai — Solo Maker Building AI Products">
  <section class="mb-16">
    <div class="text-sm text-(--color-text-dim) leading-relaxed space-y-1 font-mono">
      <p class="text-(--color-accent)">&gt; I build AI products solo.</p>
      <p class="text-(--color-accent)">&gt; 6 products. 0 employees. $15/mo infra.</p>
      <p class="text-(--color-accent)">&gt; Powered by Claude Code + custom AI agent factory.</p>
    </div>
  </section>

  <section class="mb-16">
    <h2 class="text-sm mb-6 text-(--color-text-dim)">## Products</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      {products.map(product => (
        <ProductCard {...product} />
      ))}
    </div>
    <p class="text-sm text-(--color-text-dim) mt-4">
      <a href="/products">View all products &rarr;</a>
    </p>
  </section>

  <section class="mb-16">
    <h2 class="text-sm mb-6 text-(--color-text-dim)">## Latest</h2>
    <div class="space-y-3">
      {posts.map(post => (
        <BlogPostCard
          title={post.data.title}
          slug={post.id}
          date={post.data.date}
          readingTime={post.data.readingTime}
          description={post.data.description}
        />
      ))}
    </div>
  </section>

  <section>
    <h2 class="text-sm mb-6 text-(--color-text-dim)">## Newsletter</h2>
    <Newsletter />
  </section>
</BaseLayout>
