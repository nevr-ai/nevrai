---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BlogPostCard from '../../../components/BlogPostCard.astro';
import { getCollection } from 'astro:content';
import { getTranslation } from '../../../i18n/index';

const t = getTranslation('es');
const posts = (await getCollection('blog'))
  .filter(post => post.id.startsWith('es/'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<BaseLayout title={`Blog — nevrai`} description={t.meta.description} lang="es" pagePath="/blog">
  <h1 class="text-sm mb-2 text-(--color-text-dim)">## Blog</h1>
  <p class="text-sm text-(--color-text-dim) mb-8">{t.blog.subtitle}</p>

  <div class="space-y-3">
    {posts.map(post => {
      const slug = post.id.replace('es/', '');
      return (
        <BlogPostCard
          title={post.data.title}
          slug={slug}
          date={post.data.date}
          readingTime={post.data.readingTime}
          description={post.data.description}
          basePath="/es/blog"
        />
      );
    })}
  </div>
</BaseLayout>
