---
interface Props {
  title: string;
  slug: string;
  date: Date;
  readingTime: string;
  description: string;
}

const { title, slug, date, readingTime, description } = Astro.props;
const isoDate = date.toISOString().split('T')[0];
---
<a href={`/blog/${slug}`} class="block no-underline group">
  <article class="card border border-(--color-border) p-4 sm:p-5 hover:border-(--color-accent) transition-colors bg-(--color-bg-card)">
    <div class="flex items-center gap-3 text-xs text-(--color-text-dim) mb-2 font-mono">
      <time datetime={date.toISOString()}>{isoDate}</time>
      <span>&middot;</span>
      <span>{readingTime}</span>
    </div>
    <h3 class="text-base font-semibold mb-2 m-0 !normal-case !tracking-normal text-(--color-text) group-hover:text-(--color-accent) transition-colors">
      {title}
    </h3>
    <p class="text-sm text-(--color-text-dim) m-0 leading-relaxed">{description}</p>
  </article>
</a>
