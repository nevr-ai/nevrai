---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../ProductCard.astro';
import BlogPostCard from '../BlogPostCard.astro';
import Newsletter from '../Newsletter.astro';
import PretextHero from '../PretextHero.astro';
import { getCollection } from 'astro:content';
import t from '../../content/text';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const products = [
  {
    name: 'CoffeeBot',
    tagline: t.products.taglines.coffeebot,
    url: 'https://coffeebot.app',
    status: 'LIVE' as const,
    stack: ['Astro', 'Tailwind', 'Groq'],
  },
  {
    name: 'InkCloak',
    tagline: t.products.taglines.inkcloak,
    url: 'https://inkcloak.com',
    status: 'LAUNCHING' as const,
    stack: ['Next.js', 'DeBERTa LoRA', 'RunPod GPU', 'Python'],
  },
  {
    name: 'AICPO',
    tagline: t.products.taglines.aicpo,
    url: 'https://aicpo.app',
    status: 'BUILDING' as const,
    stack: ['Rails', 'SQLite', 'Groq'],
  },
  {
    name: 'Scrutly',
    tagline: t.products.taglines.scrutly,
    url: 'https://scrutly.ai',
    status: 'PLANNED' as const,
    stack: ['Astro', 'DeBERTa'],
  },
  {
    name: 'Tool Sites',
    tagline: t.products.taglines.toolsites,
    status: 'LIVE' as const,
    stack: ['Astro', 'Tailwind', 'MDX'],
    metric: t.products.metrics.toolsites,
  },
  {
    name: 'OpenClaw Finance',
    tagline: t.products.taglines.openclaw,
    status: 'BUILT' as const,
    stack: ['Python', 'DeepSeek R1', 'Docker'],
  },
  {
    name: 'RackCloud',
    tagline: t.products.taglines.rackcloud,
    status: 'BUILT' as const,
    stack: ['Claude Opus', 'Proxmox', 'OpenStack', 'Python'],
  },
  {
    name: 'DIYCalc',
    tagline: t.products.taglines.diycalc,
    url: 'https://diycalc.co',
    status: 'LIVE' as const,
    stack: ['Astro', 'Tailwind', 'MDX'],
    metric: t.products.metrics.diycalc,
  },
  {
    name: 'FitCalc',
    tagline: t.products.taglines.fitcalc,
    url: 'https://fitcalc.co',
    status: 'LIVE' as const,
    stack: ['Astro', 'Tailwind', 'MDX'],
    metric: t.products.metrics.fitcalc,
  },
];
---
<BaseLayout title={t.meta.title} description={t.meta.description} pagePath="/">
  <section class="mb-16">
    <PretextHero />
  </section>

  <section class="mb-16">
    <h2 class="text-sm mb-6 text-(--color-text-dim)">{t.sections.products}</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      {products.map(product => (
        <ProductCard {...product} />
      ))}
    </div>
    <p class="text-sm text-(--color-text-dim) mt-4">
      <a href="/products">{t.products.viewAll}</a>
    </p>
  </section>

  <section class="mb-16">
    <h2 class="text-sm mb-6 text-(--color-text-dim)">{t.sections.latest}</h2>
    <div class="space-y-3">
      {posts.map(post => (
        <BlogPostCard
          title={post.data.title}
          slug={post.id}
          date={post.data.date}
          readingTime={post.data.readingTime}
          description={post.data.description}
        />
      ))}
    </div>
  </section>

  <section>
    <h2 class="text-sm mb-6 text-(--color-text-dim)">{t.sections.newsletter}</h2>
    <Newsletter />
  </section>
</BaseLayout>
