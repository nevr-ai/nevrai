---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../ProductCard.astro';
import BlogPostCard from '../BlogPostCard.astro';
import Newsletter from '../Newsletter.astro';
import PretextHero from '../PretextHero.astro';
import { getCollection } from 'astro:content';
import t from '../../content/text';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const standaloneProducts = [
  { name: 'CoffeeBot', tagline: t.products.taglines.coffeebot, lightTagline: t.products.taglines.light_coffeebot, url: 'https://coffeebot.app', status: 'LIVE' as const, stack: ['Astro', 'Groq', 'Tailwind', '100+ profiles', 'quiz'], metric: t.products.metrics.coffeebot, lightMetric: t.products.metrics.light_coffeebot },
  { name: 'InkCloak', tagline: t.products.taglines.inkcloak, lightTagline: t.products.taglines.light_inkcloak, url: 'https://inkcloak.com', status: 'LAUNCHING' as const, stack: ['Next.js', 'DeBERTa', 'LoRA fine-tune', 'RunPod GPU', 'AUROC 0.9948', 'CUDA'], metric: t.products.metrics.inkcloak, lightMetric: t.products.metrics.light_inkcloak },
  { name: 'Scrutly', tagline: t.products.taglines.scrutly, lightTagline: t.products.taglines.light_scrutly, url: 'https://scrutly.ai', status: 'PLANNED' as const, stack: ['Astro', 'DeBERTa', 'free'] },
  { name: 'Tool Sites', tagline: t.products.taglines.toolsites, lightTagline: t.products.taglines.light_toolsites, status: 'LIVE' as const, stack: ['Astro', 'MDX', 'programmatic SEO', '5 domains', '199 pages'], metric: t.products.metrics.toolsites, lightMetric: t.products.metrics.light_toolsites },
  { name: 'OpenClaw Finance', tagline: t.products.taglines.openclaw, lightTagline: t.products.taglines.light_openclaw, status: 'BUILT' as const, stack: ['Python', 'DeepSeek R1', 'Docker', '5 agents', 'multi-agent'], metric: t.products.metrics.openclaw, lightMetric: t.products.metrics.light_openclaw },
  { name: 'RackCloud', tagline: t.products.taglines.rackcloud, lightTagline: t.products.taglines.light_rackcloud, status: 'BUILT' as const, stack: ['Claude Opus', 'Proxmox', '400+ servers', '17 services', '10 racks'], metric: t.products.metrics.rackcloud, lightMetric: t.products.metrics.light_rackcloud },
  { name: 'DIYCalc', tagline: t.products.taglines.diycalc, lightTagline: t.products.taglines.light_diycalc, url: 'https://diycalc.co', status: 'LIVE' as const, stack: ['Astro', 'MDX', 'programmatic SEO', '30+ calculators'], metric: t.products.metrics.diycalc, lightMetric: t.products.metrics.light_diycalc },
  { name: 'FitCalc', tagline: t.products.taglines.fitcalc, lightTagline: t.products.taglines.light_fitcalc, url: 'https://fitcalc.co', status: 'LIVE' as const, stack: ['Astro', 'MDX', 'programmatic SEO', '40+ calculators'], metric: t.products.metrics.fitcalc, lightMetric: t.products.metrics.light_fitcalc },
];

// AICPO Enterprise — 5 groups
const aiEngine = [
  { name: 'Autonomous LLM Runtime', tagline: t.products.taglines.llm_runtime, lightTagline: t.products.taglines.light_llm_runtime, status: 'LIVE' as const, stack: ['Groq', 'OpenRouter', 'Claude', 'Gemini', 'Qwen', 'Llama', 'Mixtral', '7 fallback levels', 'auto-blacklist'], metric: t.products.metrics.llm_runtime, lightMetric: t.products.metrics.light_llm_runtime },
  { name: 'Dual-Brain Chat', tagline: t.products.taglines.dual_brain, lightTagline: t.products.taglines.light_dual_brain, status: 'LIVE' as const, stack: ['Groq 0.5s', 'Claude', 'load balancing', 'escalation', 'de-escalation', '-90% tokens'], metric: t.products.metrics.dual_brain, lightMetric: t.products.metrics.light_dual_brain },
  { name: 'Semantic Memory', tagline: t.products.taglines.semantic_memory, lightTagline: t.products.taglines.light_semantic_memory, status: 'LIVE' as const, stack: ['pg_vector', 'cosine similarity', '19 data points', 'project brief'], metric: t.products.metrics.semantic_memory, lightMetric: t.products.metrics.light_semantic_memory },
  { name: 'Vector Intelligence', tagline: t.products.taglines.vector_intelligence, lightTagline: t.products.taglines.light_vector_intelligence, status: 'LIVE' as const, stack: ['text\u2192facts\u2192vectors\u2192graph', 'pg_vector', '5 dimensions', 'SQLite fallback'], metric: t.products.metrics.vector_intelligence, lightMetric: t.products.metrics.light_vector_intelligence },
  { name: 'Knowledge Graph', tagline: t.products.taglines.knowledge_graph, lightTagline: t.products.taglines.light_knowledge_graph, status: 'LIVE' as const, stack: ['14 node types', '18 edge types', 'confidence scoring', 'evidence trail', 'Rails engine'], metric: t.products.metrics.knowledge_graph, lightMetric: t.products.metrics.light_knowledge_graph },
  { name: 'AI Discovery Engine', tagline: t.products.taglines.discovery, lightTagline: t.products.taglines.light_discovery, status: 'LIVE' as const, stack: ['DuckDuckGo', 'Telegram', 'vc.ru', 'Habr', '3 rounds', 'cache 90d'], metric: t.products.metrics.discovery, lightMetric: t.products.metrics.light_discovery },
];

const productIntel = [
  { name: 'AICPO Platform', tagline: t.products.taglines.aicpo_platform, lightTagline: t.products.taglines.light_aicpo_platform, url: 'https://aicpo.ru', status: 'LIVE' as const, stack: ['Rails 8', 'PostgreSQL', 'Docker', 'ActionCable', 'SSE', '31 subsystems', '43 artifacts'], metric: t.products.metrics.aicpo_platform, lightMetric: t.products.metrics.light_aicpo_platform },
  { name: 'Artifact Pipeline', tagline: t.products.taglines.artifact_pipeline, lightTagline: t.products.taglines.light_artifact_pipeline, status: 'LIVE' as const, stack: ['Groq\u2192Gemini\u2192Groq', 'structure', 'generate', 'validate', 'retry', '43 types'], metric: t.products.metrics.artifact_pipeline, lightMetric: t.products.metrics.light_artifact_pipeline },
  { name: 'Pain Extractor', tagline: t.products.taglines.pain_extractor, lightTagline: t.products.taglines.light_pain_extractor, status: 'LIVE' as const, stack: ['Rails engine', 'Groq', 'TG', 'Discord', 'Slack', 'WhatsApp', '19 fields'], metric: t.products.metrics.pain_extractor, lightMetric: t.products.metrics.light_pain_extractor },
  { name: 'Research Corpus', tagline: t.products.taglines.research_corpus, lightTagline: t.products.taglines.light_research_corpus, status: 'LIVE' as const, stack: ['PostgreSQL', 'SHA256 dedup', 'cross-user', 'TTL 90d'], metric: t.products.metrics.research_corpus, lightMetric: t.products.metrics.light_research_corpus },
  { name: 'Competitive Intelligence', tagline: t.products.taglines.competitive_intel, lightTagline: t.products.taglines.light_competitive_intel, status: 'LIVE' as const, stack: ['DuckDuckGo', 'web scrape', 'Groq', 'KG integration', 'cron 6h', 'weekly digest'], metric: t.products.metrics.competitive_intel, lightMetric: t.products.metrics.light_competitive_intel },
  { name: 'Trend Monitoring', tagline: t.products.taglines.trend_monitor, lightTagline: t.products.taglines.light_trend_monitor, status: 'LIVE' as const, stack: ['DuckDuckGo', 'Jaccard similarity', 'Groq', 'KG', 'weekly', '3 artifacts'], metric: t.products.metrics.trend_monitor, lightMetric: t.products.metrics.light_trend_monitor },
];

const autoEvolution = [
  { name: 'Self-Evolving Prompts', tagline: t.products.taglines.self_evolving, lightTagline: t.products.taglines.light_self_evolving, status: 'LIVE' as const, stack: ['weekly cron', 'Groq', 'auto-draft', 'versioning', 'rollback', 'A/B prompts'], metric: t.products.metrics.self_evolving, lightMetric: t.products.metrics.light_self_evolving },
  { name: 'Evolution Pipeline', tagline: t.products.taglines.evolution, lightTagline: t.products.taglines.light_evolution, status: 'LIVE' as const, stack: ['Claude Sonnet', 'Groq', 'daily digest', 'weekly analysis', 'voting', 'prioritization'], metric: t.products.metrics.evolution, lightMetric: t.products.metrics.light_evolution },
  { name: 'Ship Pipeline', tagline: t.products.taglines.ship_pipeline, lightTagline: t.products.taglines.light_ship_pipeline, status: 'LIVE' as const, stack: ['ActionCable', 'Groq', 'vote \u22653', 'auto-generate', 'notify'], metric: t.products.metrics.ship_pipeline, lightMetric: t.products.metrics.light_ship_pipeline },
  { name: 'Quality Management', tagline: t.products.taglines.quality_management, lightTagline: t.products.taglines.light_quality_management, status: 'LIVE' as const, stack: ['accuracy', 'completeness', 'relevance', 'staleness detection', 'prompt versioning'], metric: t.products.metrics.quality_management, lightMetric: t.products.metrics.light_quality_management },
  { name: 'Incident \u2192 Feature', tagline: t.products.taglines.incident_pipeline, lightTagline: t.products.taglines.light_incident_pipeline, status: 'LIVE' as const, stack: ['Claude Sonnet', 'Groq', '8 categories', 'chat audit', 'auto-backlog'], metric: t.products.metrics.incident_pipeline, lightMetric: t.products.metrics.light_incident_pipeline },
];

const enterprise = [
  { name: 'Team OS', tagline: t.products.taglines.team_os, lightTagline: t.products.taglines.light_team_os, status: 'LIVE' as const, stack: ['SAML 2.0', 'OIDC', 'RBAC', '4 roles', 'auto-provisioning', 'audit log', '@AI comments'], metric: t.products.metrics.team_os, lightMetric: t.products.metrics.light_team_os },
  { name: 'CRM Engine', tagline: t.products.taglines.crm_engine, lightTagline: t.products.taglines.light_crm_engine, status: 'LIVE' as const, stack: ['AI lead scoring', 'churn detector', 'reactivation', 'referral', '28 campaigns'], metric: t.products.metrics.crm_engine, lightMetric: t.products.metrics.light_crm_engine },
  { name: 'Credit Engine', tagline: t.products.taglines.credit_engine, lightTagline: t.products.taglines.light_credit_engine, status: 'LIVE' as const, stack: ['6 tiers', 'atomic deductions', 'row locks', 'BYOK', 'soft limits', 'overdraft'], metric: t.products.metrics.credit_engine, lightMetric: t.products.metrics.light_credit_engine },
  { name: 'Tokenomics Guard', tagline: t.products.taglines.tokenomics, lightTagline: t.products.taglines.light_tokenomics, status: 'LIVE' as const, stack: ['per-request tracking', '$5/day limit', 'alert 80%', 'auto-block premium'], metric: t.products.metrics.tokenomics, lightMetric: t.products.metrics.light_tokenomics },
  { name: 'P&L Economics', tagline: t.products.taglines.pnl_economics, lightTagline: t.products.taglines.light_pnl_economics, status: 'LIVE' as const, stack: ['6 tiers', 'per-member analytics', 'transaction history', 'usage %'], metric: t.products.metrics.pnl_economics, lightMetric: t.products.metrics.light_pnl_economics },
  { name: 'User Management', tagline: t.products.taglines.user_management, lightTagline: t.products.taglines.light_user_management, status: 'LIVE' as const, stack: ['invites', '3 tiers', 'shadow projects', 'claim', 'IP rate limit', 'welcome bonus'], metric: t.products.metrics.user_management, lightMetric: t.products.metrics.light_user_management },
  { name: 'Admin Command Center', tagline: t.products.taglines.admin_dashboard, lightTagline: t.products.taglines.light_admin_dashboard, status: 'LIVE' as const, stack: ['KPI', 'bulk actions', 'hotkeys', 'CRM', 'backlog', 'TG publish'], metric: t.products.metrics.admin_dashboard, lightMetric: t.products.metrics.light_admin_dashboard },
  { name: 'Marketing Analytics', tagline: t.products.taglines.marketing_analytics, lightTagline: t.products.taglines.light_marketing_analytics, status: 'LIVE' as const, stack: ['PostHog', 'GA4', 'UTM', 'funnel', 'cohorts', '28 campaigns', 'weekly reports'], metric: t.products.metrics.marketing_analytics, lightMetric: t.products.metrics.light_marketing_analytics },
];

const infra = [
  { name: 'Product Health Monitor', tagline: t.products.taglines.health_monitor, lightTagline: t.products.taglines.light_health_monitor, status: 'LIVE' as const, stack: ['PostHog', 'Stripe', 'GA4', 'Metrika', 'YooKassa', 'CloudPayments', '46 integrations'], metric: t.products.metrics.health_monitor, lightMetric: t.products.metrics.light_health_monitor },
  { name: 'Email Bridge', tagline: t.products.taglines.email_bridge, lightTagline: t.products.taglines.light_email_bridge, status: 'LIVE' as const, stack: ['IMAP poll 2min', 'SMTP', 'ActionCable', 'auto-routing', 'bounce protection'], metric: t.products.metrics.email_bridge, lightMetric: t.products.metrics.light_email_bridge },
  { name: 'PDF Publisher', tagline: t.products.taglines.pdf_publisher, lightTagline: t.products.taglines.light_pdf_publisher, status: 'LIVE' as const, stack: ['document ID', 'content freeze', 'verification', 'B4 print-ready', 'watermark'], metric: t.products.metrics.pdf_publisher, lightMetric: t.products.metrics.light_pdf_publisher },
  { name: 'TG Channel Publisher', tagline: t.products.taglines.tg_publisher, lightTagline: t.products.taglines.light_tg_publisher, status: 'LIVE' as const, stack: ['CF Worker relay', 'Telegram API', 'preview', 'scheduled posts'], metric: t.products.metrics.tg_publisher, lightMetric: t.products.metrics.light_tg_publisher },
  { name: 'Blog Publisher', tagline: t.products.taglines.blog_publisher, lightTagline: t.products.taglines.light_blog_publisher, status: 'LIVE' as const, stack: ['Markdown', 'SEO', 'preview', 'admin panel'], metric: t.products.metrics.blog_publisher, lightMetric: t.products.metrics.light_blog_publisher },
  { name: 'System Health', tagline: t.products.taglines.system_health, lightTagline: t.products.taglines.light_system_health, status: 'LIVE' as const, stack: ['health check', 'deploy status', 'alerts', 'diagnostics', 'weekly cron'], metric: t.products.metrics.system_health, lightMetric: t.products.metrics.light_system_health },
];

const aicpoGroups = [
  { category: 'Corporate', title: 'AI Engine', lightTitle: 'AI-движок', subtitle: 'LLM cascade, vector search, knowledge graph, autonomous research — AICPO build', lightSubtitle: 'Модели, память, поиск по смыслу, исследование рынка — сборка AICPO', items: aiEngine },
  { category: 'Corporate', title: 'Product Intelligence', lightTitle: 'Продуктовая аналитика', subtitle: 'Artifacts, fact extraction, competitors, trends — AICPO build', lightSubtitle: '43 документа, мониторинг конкурентов и трендов — сборка AICPO', items: productIntel },
  { category: 'Corporate', title: 'Self-Evolution', lightTitle: 'Самообучение', subtitle: 'Auto-improving prompts, feedback loops, incidents → features — reusable modules', lightSubtitle: 'Система учится на ошибках и развивается без участия человека', items: autoEvolution },
  { category: 'Corporate', title: 'Enterprise', lightTitle: 'Корпоративные функции', subtitle: 'RBAC, SSO, CRM, billing, analytics, admin — reusable modules', lightSubtitle: 'Командная работа, тарификация, CRM, маркетинговая аналитика', items: enterprise },
  { category: 'Corporate', title: 'Integrations', lightTitle: 'Интеграции', subtitle: 'Monitoring, email, PDF, TG, blog, health checks — reusable modules', lightSubtitle: 'Мониторинг метрик, email, документы, публикации', items: infra },
];
---
<BaseLayout title={t.meta.title} description={t.meta.description} pagePath="/">
  <section class="mb-16">
    <PretextHero />
  </section>

  <!-- Indie Products -->
  <section class="mb-12">
    <h2 class="text-sm mb-1 text-(--color-text-dim)">
      <span class="theme-dark">## Indie Products</span>
      <span class="theme-light">## Самостоятельные продукты</span>
    </h2>
    <p class="text-xs text-(--color-text-dim) mb-4">
      <span class="theme-dark">Astro, Next.js, Python, Cloudflare — standalone</span>
      <span class="theme-light">Отдельные продукты, запущенные в продакшен</span>
    </p>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      {standaloneProducts.map(product => (
        <ProductCard {...product} />
      ))}
    </div>
  </section>

  <!-- Corporate modules (nevrai framework → AICPO build) -->
  {aicpoGroups.map(group => (
    <section class="mb-12">
      <h2 class="text-sm mb-1 text-(--color-text-dim)">
        <span class="theme-dark">## {group.category} / {group.title}</span>
        <span class="theme-light">## {group.category} / {group.lightTitle}</span>
      </h2>
      <p class="text-xs text-(--color-text-dim) mb-4">
        <span class="theme-dark">{group.subtitle}</span>
        <span class="theme-light">{group.lightSubtitle}</span>
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        {group.items.map(product => (
          <ProductCard {...product} />
        ))}
      </div>
    </section>
  ))}

  <p class="text-sm text-(--color-text-dim) mt-4 mb-16">
    <a href="/products">{t.products.viewAll}</a>
  </p>

  <section class="mb-16">
    <h2 class="text-sm mb-6 text-(--color-text-dim)">{t.sections.latest}</h2>
    <div class="space-y-3">
      {posts.map(post => (
        <BlogPostCard
          title={post.data.title}
          slug={post.id}
          date={post.data.date}
          readingTime={post.data.readingTime}
          description={post.data.description}
        />
      ))}
    </div>
  </section>

  <section>
    <h2 class="text-sm mb-6 text-(--color-text-dim)">{t.sections.newsletter}</h2>
    <Newsletter />
  </section>
</BaseLayout>
