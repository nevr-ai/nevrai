---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../ProductCard.astro';
import BlogPostCard from '../BlogPostCard.astro';
import Newsletter from '../Newsletter.astro';
import PretextHero from '../PretextHero.astro';
import { getCollection } from 'astro:content';
import t from '../../content/text';
import { products } from '../../content/products';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const indie = products.filter(p => p.group === 'indie');

const corpGroups = [
  { group: 'ai-engine' as const, title: 'AI Engine', lightTitle: 'AI-движок', subtitle: 'LLM cascade, vector search, knowledge graph, autonomous research — AICPO build', lightSubtitle: 'Модели, память, поиск по смыслу, исследование рынка — сборка AICPO' },
  { group: 'product-intel' as const, title: 'Product Intelligence', lightTitle: 'Продуктовая аналитика', subtitle: 'Artifacts, fact extraction, competitors, trends — AICPO build', lightSubtitle: '43 документа, мониторинг конкурентов и трендов — сборка AICPO' },
  { group: 'self-evolution' as const, title: 'Self-Evolution', lightTitle: 'Самообучение', subtitle: 'Auto-improving prompts, feedback loops, incidents → features — reusable modules', lightSubtitle: 'Система учится на ошибках и развивается без участия человека' },
  { group: 'enterprise' as const, title: 'Enterprise', lightTitle: 'Корпоративные функции', subtitle: 'RBAC, SSO, CRM, billing, analytics, admin — reusable modules', lightSubtitle: 'Командная работа, тарификация, CRM, маркетинговая аналитика' },
  { group: 'integrations' as const, title: 'Integrations', lightTitle: 'Интеграции', subtitle: 'Monitoring, email, PDF, TG, blog, health checks — reusable modules', lightSubtitle: 'Мониторинг метрик, email, документы, публикации' },
];
---
<BaseLayout title={t.meta.title} description={t.meta.description} pagePath="/">
  <section class="mb-16">
    <PretextHero />
  </section>

  <!-- Indie Products -->
  <section class="mb-12">
    <h2 class="text-sm mb-1 text-(--color-text-dim)">
      <span class="theme-dark">## Indie Products</span>
      <span class="theme-light">## Самостоятельные продукты</span>
    </h2>
    <p class="text-xs text-(--color-text-dim) mb-4">
      <span class="theme-dark">Astro, Next.js, Python, Cloudflare — standalone</span>
      <span class="theme-light">Отдельные продукты, запущенные в продакшен</span>
    </p>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      {indie.map(p => (
        <ProductCard
          name={p.name}
          tagline={p.tagline}
          lightTagline={p.lightTagline}
          url={p.url}
          status={p.status}
          stack={p.stack}
          metric={p.metric}
          lightMetric={p.lightMetric}
        />
      ))}
    </div>
  </section>

  <!-- Corporate modules -->
  {corpGroups.map(g => {
    const items = products.filter(p => p.group === g.group);
    return (
      <section class="mb-12">
        <h2 class="text-sm mb-1 text-(--color-text-dim)">
          <span class="theme-dark">## Corporate / {g.title}</span>
          <span class="theme-light">## Corporate / {g.lightTitle}</span>
        </h2>
        <p class="text-xs text-(--color-text-dim) mb-4">
          <span class="theme-dark">{g.subtitle}</span>
          <span class="theme-light">{g.lightSubtitle}</span>
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {items.map(p => (
            <ProductCard
              name={p.name}
              tagline={p.tagline}
              lightTagline={p.lightTagline}
              url={p.url}
              status={p.status}
              stack={p.stack}
              metric={p.metric}
              lightMetric={p.lightMetric}
            />
          ))}
        </div>
      </section>
    );
  })}

  <p class="text-sm text-(--color-text-dim) mt-4 mb-16">
    <a href="/products">{t.products.viewAll}</a>
  </p>

  <section class="mb-16">
    <h2 class="text-sm mb-6 text-(--color-text-dim)">{t.sections.latest}</h2>
    <div class="space-y-3">
      {posts.map(post => (
        <BlogPostCard
          title={post.data.title}
          slug={post.id}
          date={post.data.date}
          readingTime={post.data.readingTime}
          description={post.data.description}
        />
      ))}
    </div>
  </section>

  <section>
    <h2 class="text-sm mb-6 text-(--color-text-dim)">{t.sections.newsletter}</h2>
    <Newsletter />
  </section>
</BaseLayout>
