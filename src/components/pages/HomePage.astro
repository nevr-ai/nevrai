---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../ProductCard.astro';
import BlogPostCard from '../BlogPostCard.astro';
import Newsletter from '../Newsletter.astro';
import PretextHero from '../PretextHero.astro';
import { getCollection } from 'astro:content';
import t from '../../content/text';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const standaloneProducts = [
  { name: 'CoffeeBot', tagline: t.products.taglines.coffeebot, url: 'https://coffeebot.app', status: 'LIVE' as const, stack: ['Astro', 'Groq', 'Tailwind'], metric: t.products.metrics.coffeebot },
  { name: 'InkCloak', tagline: t.products.taglines.inkcloak, url: 'https://inkcloak.com', status: 'LAUNCHING' as const, stack: ['Next.js', 'DeBERTa LoRA', 'RunPod GPU'], metric: t.products.metrics.inkcloak },
  { name: 'Scrutly', tagline: t.products.taglines.scrutly, url: 'https://scrutly.ai', status: 'PLANNED' as const, stack: ['Astro', 'DeBERTa'] },
  { name: 'Tool Sites', tagline: t.products.taglines.toolsites, status: 'LIVE' as const, stack: ['Astro', 'MDX'], metric: t.products.metrics.toolsites },
  { name: 'OpenClaw Finance', tagline: t.products.taglines.openclaw, status: 'BUILT' as const, stack: ['Python', 'DeepSeek R1', 'Docker'], metric: t.products.metrics.openclaw },
  { name: 'RackCloud', tagline: t.products.taglines.rackcloud, status: 'BUILT' as const, stack: ['Claude Opus', 'Proxmox', 'Python'], metric: t.products.metrics.rackcloud },
  { name: 'DIYCalc', tagline: t.products.taglines.diycalc, url: 'https://diycalc.co', status: 'LIVE' as const, stack: ['Astro', 'MDX'], metric: t.products.metrics.diycalc },
  { name: 'FitCalc', tagline: t.products.taglines.fitcalc, url: 'https://fitcalc.co', status: 'LIVE' as const, stack: ['Astro', 'MDX'], metric: t.products.metrics.fitcalc },
];

const aicpoProducts = [
  { name: 'AICPO Platform', tagline: t.products.taglines.aicpo_platform, url: 'https://aicpo.ru', status: 'LIVE' as const, stack: ['Rails 8', 'ActionCable', 'Propshaft'], metric: t.products.metrics.aicpo_platform },
  { name: 'Autonomous LLM Runtime', tagline: t.products.taglines.llm_runtime, status: 'LIVE' as const, stack: ['Groq', 'OpenRouter', 'Redis'], metric: t.products.metrics.llm_runtime },
  { name: 'AI Discovery Engine', tagline: t.products.taglines.discovery, status: 'LIVE' as const, stack: ['DuckDuckGo', 'Groq', 'PostgreSQL'], metric: t.products.metrics.discovery },
  { name: 'Dual-Brain Chat', tagline: t.products.taglines.dual_brain, status: 'LIVE' as const, stack: ['Groq 0.5с', 'Claude', 'SSE'], metric: t.products.metrics.dual_brain },
  { name: 'Artifact Pipeline', tagline: t.products.taglines.artifact_pipeline, status: 'LIVE' as const, stack: ['Groq', 'Gemini', 'OpenRouter'], metric: t.products.metrics.artifact_pipeline },
  { name: 'Semantic Memory', tagline: t.products.taglines.semantic_memory, status: 'LIVE' as const, stack: ['pg_vector', 'cosine similarity'], metric: t.products.metrics.semantic_memory },
  { name: 'Product Health Monitor', tagline: t.products.taglines.health_monitor, status: 'LIVE' as const, stack: ['PostHog', 'Stripe', 'GA4', 'Метрика'], metric: t.products.metrics.health_monitor },
  { name: 'Team OS', tagline: t.products.taglines.team_os, status: 'LIVE' as const, stack: ['SAML 2.0', 'OIDC', 'RBAC'], metric: t.products.metrics.team_os },
  { name: 'Self-Evolving Prompts', tagline: t.products.taglines.self_evolving, status: 'LIVE' as const, stack: ['Groq', 'cron'], metric: t.products.metrics.self_evolving },
  { name: 'Evolution Pipeline', tagline: t.products.taglines.evolution, status: 'LIVE' as const, stack: ['Claude Sonnet', 'Groq'], metric: t.products.metrics.evolution },
  { name: 'Research Corpus', tagline: t.products.taglines.research_corpus, status: 'LIVE' as const, stack: ['PostgreSQL', 'SHA256'], metric: t.products.metrics.research_corpus },
  { name: 'Pain Extractor', tagline: t.products.taglines.pain_extractor, status: 'LIVE' as const, stack: ['Rails engine', 'Groq'], metric: t.products.metrics.pain_extractor },
  { name: 'Credit Engine', tagline: t.products.taglines.credit_engine, status: 'LIVE' as const, stack: ['PostgreSQL', 'row locks'], metric: t.products.metrics.credit_engine },
  { name: 'Tokenomics Guard', tagline: t.products.taglines.tokenomics, status: 'LIVE' as const, stack: ['Redis', 'PostgreSQL'], metric: t.products.metrics.tokenomics },
  { name: 'Email Bridge', tagline: t.products.taglines.email_bridge, status: 'LIVE' as const, stack: ['IMAP', 'SMTP', 'ActionCable'], metric: t.products.metrics.email_bridge },
  { name: 'PDF Publisher', tagline: t.products.taglines.pdf_publisher, status: 'LIVE' as const, stack: ['Rails', 'HTML→PDF'], metric: t.products.metrics.pdf_publisher },
  { name: 'Vector Intelligence Engine', tagline: t.products.taglines.vector_intelligence, status: 'LIVE' as const, stack: ['pg_vector', 'cosine similarity', 'SQLite fallback'], metric: t.products.metrics.vector_intelligence },
  { name: 'Knowledge Graph', tagline: t.products.taglines.knowledge_graph, status: 'LIVE' as const, stack: ['Rails engine', '14 node types', 'edges'], metric: t.products.metrics.knowledge_graph },
  { name: 'Admin Command Center', tagline: t.products.taglines.admin_dashboard, status: 'LIVE' as const, stack: ['Rails', 'Turbo', 'Hotkeys'], metric: t.products.metrics.admin_dashboard },
  { name: 'CRM Engine', tagline: t.products.taglines.crm_engine, status: 'LIVE' as const, stack: ['Rails', 'cron', 'SMTP'], metric: t.products.metrics.crm_engine },
  { name: 'Marketing Analytics', tagline: t.products.taglines.marketing_analytics, status: 'LIVE' as const, stack: ['PostHog', 'GA4', 'UTM'], metric: t.products.metrics.marketing_analytics },
  { name: 'Ship Pipeline', tagline: t.products.taglines.ship_pipeline, status: 'LIVE' as const, stack: ['ActionCable', 'Groq', 'voting'], metric: t.products.metrics.ship_pipeline },
  { name: 'TG Channel Publisher', tagline: t.products.taglines.tg_publisher, status: 'LIVE' as const, stack: ['CF Worker', 'Telegram API'], metric: t.products.metrics.tg_publisher },
  { name: 'Blog Publisher', tagline: t.products.taglines.blog_publisher, status: 'LIVE' as const, stack: ['Rails', 'Markdown', 'SEO'], metric: t.products.metrics.blog_publisher },
  { name: 'Incident → Feature Pipeline', tagline: t.products.taglines.incident_pipeline, status: 'LIVE' as const, stack: ['Claude Sonnet', 'Groq', '8 categories'], metric: t.products.metrics.incident_pipeline },
  { name: 'P&L Economics', tagline: t.products.taglines.pnl_economics, status: 'LIVE' as const, stack: ['PostgreSQL', 'row locks', 'cron'], metric: t.products.metrics.pnl_economics },
  { name: 'Quality Management', tagline: t.products.taglines.quality_management, status: 'LIVE' as const, stack: ['feedback', 'auto-draft', 'versioning'], metric: t.products.metrics.quality_management },
  { name: 'System Health', tagline: t.products.taglines.system_health, status: 'LIVE' as const, stack: ['Rails', 'cron', 'ActionCable'], metric: t.products.metrics.system_health },
  { name: 'User Management', tagline: t.products.taglines.user_management, status: 'LIVE' as const, stack: ['Rails', 'invites', 'shadow projects'], metric: t.products.metrics.user_management },
];
---
<BaseLayout title={t.meta.title} description={t.meta.description} pagePath="/">
  <section class="mb-16">
    <PretextHero />
  </section>

  <section class="mb-16">
    <h2 class="text-sm mb-6 text-(--color-text-dim)">{t.sections.products}</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      {standaloneProducts.map(product => (
        <ProductCard {...product} />
      ))}
    </div>
    <h2 class="text-sm mt-12 mb-6 text-(--color-text-dim)">## AICPO Platform — 16 систем под одним капотом</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      {aicpoProducts.map(product => (
        <ProductCard {...product} />
      ))}
    </div>
    <p class="text-sm text-(--color-text-dim) mt-4">
      <a href="/products">{t.products.viewAll}</a>
    </p>
  </section>

  <section class="mb-16">
    <h2 class="text-sm mb-6 text-(--color-text-dim)">{t.sections.latest}</h2>
    <div class="space-y-3">
      {posts.map(post => (
        <BlogPostCard
          title={post.data.title}
          slug={post.id}
          date={post.data.date}
          readingTime={post.data.readingTime}
          description={post.data.description}
        />
      ))}
    </div>
  </section>

  <section>
    <h2 class="text-sm mb-6 text-(--color-text-dim)">{t.sections.newsletter}</h2>
    <Newsletter />
  </section>
</BaseLayout>
