---
import BaseLayout from '../../layouts/BaseLayout.astro';
import t from '../../content/text';
---
<BaseLayout title={t.about.title} description={t.about.description} pagePath="/about">
  <h1 class="text-sm mb-2 text-(--color-text-dim)">{t.about.heading}</h1>

  <!-- Dark theme (tech) -->
  <div class="theme-dark-block prose text-sm leading-relaxed space-y-4 text-(--color-text)">
    <p>{t.about.bio1}</p>
    <p set:html={t.about.bio2} />
    <p set:html={t.about.bio3} />
    <p set:html={t.about.bio4} />
    <p set:html={t.about.bio5} />
    <p set:html={t.about.bio6} />
    <p set:html={t.about.bio7} />
  </div>

  <!-- Light theme (business) -->
  <div class="theme-light-block prose text-sm leading-relaxed space-y-4 text-(--color-text)">
    <p>{t.about.light_bio1}</p>
    <p set:html={t.about.light_bio2} />
    <p set:html={t.about.light_bio3} />
    <p set:html={t.about.light_bio4} />
    <p set:html={t.about.light_bio5} />
    <p set:html={t.about.light_bio6} />
    <p set:html={t.about.light_bio7} />
  </div>

  <div class="prose text-sm leading-relaxed space-y-4 text-(--color-text)">
    <h2 class="text-sm mt-8 mb-4 text-(--color-text-dim)">{t.about.linksHeading}</h2>

    <ul class="space-y-2 list-none p-0">
      <li><a href={t.links.githubUrl} target="_blank" rel="noopener">GitHub</a> — {t.about.githubLabel}</li>
      <li><a href={t.links.telegramUrl} target="_blank" rel="noopener">Telegram</a> — {t.about.tgLabel}</li>
      <li><a href={`mailto:${t.links.email}`}>{t.links.email}</a> — {t.about.emailLabel}</li>
    </ul>

    <h2 class="text-sm mt-8 mb-4 text-(--color-text-dim)">{t.about.nowHeading}</h2>

    <ul class="space-y-2 list-none p-0">
      <li>{t.about.now1}</li>
      <li>{t.about.now2}</li>
      <li>{t.about.now3}</li>
    </ul>
  </div>
</BaseLayout>
