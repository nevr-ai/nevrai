---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Newsletter from '../Newsletter.astro';
import { getTranslation, type Lang } from '../../i18n/index';

interface Props {
  lang?: Lang;
}

const { lang = 'en' } = Astro.props;
const t = getTranslation(lang);
---
<BaseLayout title={t.newsletter.title} description={t.newsletter.description} lang={lang}>
  <h1 class="text-sm mb-2 text-(--color-text-dim)">{t.newsletter.heading}</h1>

  <div class="space-y-6">
    <div class="text-sm text-(--color-text) leading-relaxed space-y-4">
      <p>{t.newsletter.followBuild}</p>
      <p>{t.newsletter.followDesc}</p>
      <p>{t.newsletter.unsubscribe}</p>
    </div>

    <Newsletter lang={lang} />

    <div class="text-sm text-(--color-text-dim) space-y-2">
      <p>{t.newsletter.previousTopics}</p>
      <ul class="list-none p-0 space-y-1">
        <li class="font-mono text-xs">{t.newsletter.topic1}</li>
        <li class="font-mono text-xs">{t.newsletter.topic2}</li>
        <li class="font-mono text-xs">{t.newsletter.topic3}</li>
      </ul>
    </div>
  </div>
</BaseLayout>
