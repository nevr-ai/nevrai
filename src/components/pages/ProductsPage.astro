---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../ProductCard.astro';
import t from '../../content/text';
import { products } from '../../content/products';

const indie = products.filter(p => p.group === 'indie');

const groups = [
  { group: 'ai-engine', title: 'AI Engine', lightTitle: 'AI-движок', subtitle: 'LLM cascade, vector search, knowledge graph, autonomous research — AICPO build', lightSubtitle: 'Модели, память, поиск по смыслу, исследование рынка — сборка AICPO' },
  { group: 'product-intel', title: 'Product Intelligence', lightTitle: 'Продуктовая аналитика', subtitle: 'Artifacts, fact extraction, competitors, trends — AICPO build', lightSubtitle: '43 документа, мониторинг конкурентов и трендов — сборка AICPO' },
  { group: 'self-evolution', title: 'Self-Evolution', lightTitle: 'Самообучение', subtitle: 'Auto-improving prompts, feedback loops, incidents → features — reusable modules', lightSubtitle: 'Система учится на ошибках и развивается без участия человека' },
  { group: 'enterprise', title: 'Enterprise', lightTitle: 'Корпоративные функции', subtitle: 'RBAC, SSO, CRM, billing, analytics, admin — reusable modules', lightSubtitle: 'Командная работа, тарификация, CRM, маркетинговая аналитика' },
  { group: 'integrations', title: 'Integrations', lightTitle: 'Интеграции', subtitle: 'Monitoring, email, PDF, TG, blog, health checks — reusable modules', lightSubtitle: 'Мониторинг метрик, email, документы, публикации' },
] as const;
---
<BaseLayout title={t.products.title} description={t.products.description} pagePath="/products">
  <h1 class="text-sm mb-2 text-(--color-text-dim)">{t.sections.products}</h1>
  <p class="text-sm text-(--color-text-dim) mb-8">
    <span class="theme-dark">{t.products.subtitle}</span>
    <span class="theme-light">{t.products.light_subtitle}</span>
  </p>

  <!-- Indie -->
  <section class="mb-12">
    <h2 class="text-sm mb-1 text-(--color-text-dim)">
      <span class="theme-dark">## Indie Products</span>
      <span class="theme-light">## Самостоятельные продукты</span>
    </h2>
    <p class="text-xs text-(--color-text-dim) mb-4">
      <span class="theme-dark">Astro, Next.js, Python, Cloudflare — standalone</span>
      <span class="theme-light">Отдельные продукты, запущенные в продакшен</span>
    </p>
    <div class="grid grid-cols-1 gap-3">
      {indie.map(p => (
        <ProductCard
          name={p.name}
          tagline={p.tagline}
          lightTagline={p.lightTagline}
          url={p.url}
          status={p.status}
          stack={p.stack}
          metric={p.metric}
          lightMetric={p.lightMetric}
        />
      ))}
    </div>
  </section>

  <!-- Corporate groups -->
  {groups.map(g => {
    const items = products.filter(p => p.group === g.group);
    return (
      <section class="mb-12">
        <h2 class="text-sm mb-1 text-(--color-text-dim)">
          <span class="theme-dark">## Corporate / {g.title}</span>
          <span class="theme-light">## Corporate / {g.lightTitle}</span>
        </h2>
        <p class="text-xs text-(--color-text-dim) mb-4">
          <span class="theme-dark">{g.subtitle}</span>
          <span class="theme-light">{g.lightSubtitle}</span>
        </p>
        <div class="grid grid-cols-1 gap-3">
          {items.map(p => (
            <ProductCard
              name={p.name}
              tagline={p.tagline}
              lightTagline={p.lightTagline}
              url={p.url}
              status={p.status}
              stack={p.stack}
              metric={p.metric}
              lightMetric={p.lightMetric}
            />
          ))}
        </div>
      </section>
    );
  })}
</BaseLayout>
