---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getTranslation, type Lang } from '../../i18n/index';

interface Props {
  lang?: Lang;
}

const { lang = 'en' } = Astro.props;
const t = getTranslation(lang);

const stack = [
  { service: 'Cloudflare Workers', cost: '$0', what: 'Compute + hosting', limit: '100K req/day' },
  { service: 'Vercel', cost: '$0', what: 'Next.js hosting', limit: '100GB bandwidth' },
  { service: 'Supabase', cost: '$0', what: 'Auth + Database', limit: '500MB DB' },
  { service: 'Groq', cost: '$0', what: 'LLM inference', limit: '14K tokens/min' },
  { service: 'PostHog', cost: '$0', what: 'Analytics', limit: '1M events/mo' },
  { service: 'Loops.so', cost: '$0', what: 'Email drip', limit: '1K contacts' },
  { service: 'Sentry', cost: '$0', what: 'Error monitoring', limit: '5K errors/mo' },
  { service: 'RunPod', cost: '$0.49 once', what: 'ML training', limit: 'Pay per use' },
  { service: 'NVIDIA P100', cost: '$150 once', what: 'GPU inference', limit: 'Own hardware' },
  { service: 'Domains (5)', cost: '$15/mo', what: '.com .app .ai', limit: '\u2014' },
];

const savings = [
  { service: 'AWS/GCP compute', paid: '$200/mo', using: 'Cloudflare Workers' },
  { service: 'Vercel Pro', paid: '$20/mo', using: 'Free tier' },
  { service: 'Database hosting', paid: '$50/mo', using: 'Supabase free + SQLite' },
  { service: 'OpenAI API', paid: '$100/mo', using: 'Groq free tier' },
  { service: 'Mixpanel/Amplitude', paid: '$100/mo', using: 'PostHog free' },
  { service: 'Mailchimp', paid: '$30/mo', using: 'Loops.so free' },
  { service: 'GPU cloud (always-on)', paid: '$300/mo', using: 'Own P100 + RunPod spot' },
];

const totalSaved = savings.reduce((sum, s) => {
  const match = s.paid.match(/\$(\d+)/);
  return sum + (match ? parseInt(match[1]) : 0);
}, 0);
---
<BaseLayout title={t.stack.title} description={t.stack.description} lang={lang} pagePath="/stack">
  <h1 class="text-sm mb-2 text-(--color-text-dim)">{t.stack.heading}</h1>
  <p class="text-sm text-(--color-text-dim) mb-8">{t.stack.subtitle}</p>

  <div class="overflow-x-auto mb-12">
    <table>
      <thead>
        <tr>
          <th>{t.stack.headers.service}</th>
          <th>{t.stack.headers.cost}</th>
          <th>{t.stack.headers.what}</th>
          <th>{t.stack.headers.limit}</th>
        </tr>
      </thead>
      <tbody>
        {stack.map(row => (
          <tr>
            <td class="font-semibold">{row.service}</td>
            <td class="text-(--color-accent) font-mono text-sm">{row.cost}</td>
            <td class="text-(--color-text-dim)">{row.what}</td>
            <td class="text-(--color-text-dim) text-sm">{row.limit}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <h2 class="text-sm mb-6 text-(--color-text-dim)">{t.stack.savedHeading}</h2>
  <p class="text-sm text-(--color-text-dim) mb-6">{t.stack.savedSubtitle}</p>

  <div class="overflow-x-auto mb-8">
    <table>
      <thead>
        <tr>
          <th>{t.stack.savedHeaders.wouldPay}</th>
          <th>{t.stack.savedHeaders.cost}</th>
          <th>{t.stack.savedHeaders.using}</th>
        </tr>
      </thead>
      <tbody>
        {savings.map(row => (
          <tr>
            <td class="text-(--color-text-dim)">{row.service}</td>
            <td class="font-mono text-sm line-through text-(--color-text-dim)">{row.paid}</td>
            <td class="text-(--color-accent) text-sm">{row.using}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <div class="border border-(--color-accent) p-4 text-center bg-(--color-bg-card) card">
    <p class="text-sm text-(--color-text-dim) mb-1">{t.stack.totalSavings}</p>
    <p class="text-2xl font-bold text-(--color-accent) font-mono m-0">${totalSaved}+/mo</p>
  </div>
</BaseLayout>
