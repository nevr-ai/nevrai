---
import { getTranslation, type Lang } from '../i18n/index';

interface Props {
  lang?: Lang;
}

const { lang = 'en' } = Astro.props;
const t = getTranslation(lang);
const longText = t.hero.longText;
---

<div class="mb-8">
  <!-- Tagline and subtitle — always visible, not part of pretext animation -->
  <p class="text-lg font-bold mb-1 text-(--color-accent)">{t.hero.line1}</p>
  <p class="text-sm mb-6 text-(--color-text-dim)">{t.hero.line2}</p>
</div>

<div id="pretext-hero" class="relative">
  <!-- Static fallback text — visible until animation starts -->
  <div id="pretext-lines" class="text-sm leading-relaxed font-mono whitespace-pre-line text-(--color-text-secondary)">
    {longText}
  </div>
  <!-- Orb overlays -->
  <div id="pretext-orb-0" class="pretext-orb pointer-events-none absolute rounded-full opacity-0" style="width:100px;height:100px;"></div>
  <div id="pretext-orb-1" class="pretext-orb pointer-events-none absolute rounded-full opacity-0" style="width:60px;height:60px;"></div>
  <div id="pretext-orb-2" class="pretext-orb pointer-events-none absolute rounded-full opacity-0" style="width:40px;height:40px;"></div>
  <!-- Pretext-rendered text (hidden until animation starts) -->
  <div id="pretext-canvas" class="absolute inset-0 text-sm font-mono" style="display:none;"></div>
</div>

<style>
  .pretext-orb {
    filter: blur(20px);
    z-index: 1;
    transition: opacity 0.6s ease;
  }
  #pretext-canvas {
    z-index: 0;
  }
  #pretext-canvas span {
    position: absolute;
    white-space: pre;
    color: var(--color-text-secondary, var(--color-accent));
  }

  @media (max-width: 640px) {
    .pretext-orb {
      filter: blur(12px);
    }
  }
</style>

<script define:vars={{ longText }}>
  async function initPretextAnimation() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const container = document.getElementById('pretext-hero');
    const staticLines = document.getElementById('pretext-lines');
    const canvas = document.getElementById('pretext-canvas');
    if (!container || !staticLines || !canvas) return;

    // Collect orb elements
    const orbEls = [
      document.getElementById('pretext-orb-0'),
      document.getElementById('pretext-orb-1'),
      document.getElementById('pretext-orb-2'),
    ].filter(Boolean);

    if (orbEls.length === 0) return;

    // Dynamically import pretext
    let pretext;
    try {
      // Use globalThis to cache the module
      if (window.__pretextModule) {
        pretext = window.__pretextModule;
      } else {
        // Static import via dynamic — Cloudflare Pages compatible
        pretext = await import('@chenglou/pretext');
        window.__pretextModule = pretext;
      }
    } catch (e) {
      // Pretext unavailable — static text stays visible
      console.warn('Pretext not loaded, falling back to static text');
      return;
    }

    const computedStyle = getComputedStyle(staticLines);
    const fontSize = computedStyle.fontSize || '14px';
    const fontFamily = computedStyle.fontFamily || 'monospace';
    const font = `${fontSize} ${fontFamily}`;
    const lineHeight = parseFloat(computedStyle.lineHeight) || parseFloat(fontSize) * 1.625;

    const isMobile = window.innerWidth < 640;

    // Orb configuration: radius, phase offset (seconds), speed multiplier, path type
    const orbConfigs = [
      { radius: isMobile ? 30 : 50, delay: 3000, speed: 0.0003, pathFn: 'sine' },
      { radius: isMobile ? 18 : 30, delay: 5000, speed: 0.00025, pathFn: 'cosine' },
      { radius: isMobile ? 12 : 20, delay: 7000, speed: 0.00035, pathFn: 'diagonal' },
    ];

    // Track orb positions
    const orbPositions = orbConfigs.map(() => ({ x: -200, y: -200, r: 0, active: false }));

    function getOrbGradient(opacity) {
      const isLight = document.documentElement.classList.contains('light');
      if (isLight) {
        return `radial-gradient(circle, rgba(59,130,246,${opacity}) 0%, rgba(59,130,246,0) 70%)`;
      }
      return `radial-gradient(circle, rgba(34,197,94,${opacity}) 0%, rgba(34,197,94,0) 70%)`;
    }

    function layoutText(obstacles, containerWidth) {
      canvas.innerHTML = '';

      const paragraphs = longText.split('\n\n');
      let globalY = 0;

      for (const para of paragraphs) {
        if (!para.trim()) continue;
        const prepared = pretext.prepareWithSegments(para, font);
        let cursor = { segmentIndex: 0, graphemeIndex: 0 };
        let safety = 0;

        while (safety < 500) {
          safety++;
          let lineX = 0;
          let maxWidth = containerWidth;

          // Check ALL obstacles (orbs) for this line
          const lineTop = globalY;
          const lineBottom = globalY + lineHeight;

          for (const obs of obstacles) {
            if (!obs.active) continue;
            const orbTop = obs.y - obs.r;
            const orbBottom = obs.y + obs.r;

            if (lineBottom > orbTop && lineTop < orbBottom) {
              const lineMid = (lineTop + lineBottom) / 2;
              const dy = Math.abs(obs.y - lineMid);
              if (dy < obs.r) {
                const dx = Math.sqrt(obs.r * obs.r - dy * dy);
                const orbLeft = obs.x - dx;
                const orbRight = obs.x + dx;

                if (orbLeft <= containerWidth * 0.5) {
                  const newLineX = Math.max(lineX, orbRight + 8);
                  lineX = newLineX;
                  maxWidth = containerWidth - lineX;
                } else {
                  maxWidth = Math.min(maxWidth, Math.max(40, orbLeft - 8) - lineX);
                }
              }
            }
          }

          if (maxWidth < 40) maxWidth = 40;

          const line = pretext.layoutNextLine(prepared, cursor, maxWidth);
          if (line === null) break;

          const span = document.createElement('span');
          span.textContent = line.text;
          span.style.left = `${lineX}px`;
          span.style.top = `${globalY}px`;
          canvas.appendChild(span);

          cursor = line.end;
          globalY += lineHeight;
        }

        // Paragraph gap
        globalY += lineHeight * 0.5;
      }

      // Update container height to match rendered text
      const totalHeight = Math.max(globalY, staticLines.scrollHeight);
      canvas.style.height = `${totalHeight}px`;
      container.style.minHeight = `${totalHeight}px`;
    }

    // Path functions: each returns {x, y} normalized to [0..1] range
    function sinePathPosition(t) {
      // Slow horizontal sweep with vertical sine wave
      const x = (Math.sin(t * 0.7) + 1) / 2;
      const y = (Math.sin(t * 1.3) + 1) / 2;
      return { x, y };
    }

    function cosinePathPosition(t) {
      const x = (Math.cos(t * 0.5 + 1) + 1) / 2;
      const y = (Math.cos(t * 0.9 + 2) + 1) / 2;
      return { x, y };
    }

    function diagonalPathPosition(t) {
      const x = (Math.sin(t * 0.6 + 3) + 1) / 2;
      const y = (Math.sin(t * 0.4 + 1.5) * Math.cos(t * 0.3) + 1) / 2;
      return { x, y };
    }

    const pathFns = { sine: sinePathPosition, cosine: cosinePathPosition, diagonal: diagonalPathPosition };

    let animFrameId = null;
    let startTime = null;
    let running = false;

    function startAnimation() {
      if (running) return;
      running = true;

      const containerWidth = container.clientWidth;
      const containerHeight = staticLines.scrollHeight;

      container.style.minHeight = `${containerHeight}px`;
      canvas.style.display = 'block';
      staticLines.style.visibility = 'hidden';

      // Initial layout without obstacles
      layoutText(orbPositions, containerWidth);

      startTime = performance.now();

      function animate(now) {
        const elapsed = now - startTime;
        const containerW = container.clientWidth;
        const containerH = parseInt(container.style.minHeight) || containerHeight;

        // Padding from edges so orbs don't go out of bounds
        const padX = 60;
        const padY = 40;

        for (let i = 0; i < orbConfigs.length; i++) {
          const cfg = orbConfigs[i];
          const orbEl = orbEls[i];
          if (!orbEl) continue;

          if (elapsed < cfg.delay) {
            orbPositions[i].active = false;
            orbEl.style.opacity = '0';
            continue;
          }

          // Activate and fade in
          orbPositions[i].active = true;
          const fadeIn = Math.min((elapsed - cfg.delay) / 1000, 1);
          const opacity = 0.3 + fadeIn * 0.3;
          orbEl.style.opacity = String(fadeIn * 0.8);
          orbEl.style.background = getOrbGradient(opacity);

          // Calculate position from path function
          const t = (elapsed - cfg.delay) * cfg.speed;
          const pathFn = pathFns[cfg.pathFn];
          const pos = pathFn(t);

          const orbX = padX + pos.x * (containerW - padX * 2);
          const orbY = padY + pos.y * (containerH - padY * 2);

          orbPositions[i].x = orbX;
          orbPositions[i].y = orbY;
          orbPositions[i].r = cfg.radius;

          // Position the DOM element (center of orb)
          const size = cfg.radius * 2;
          orbEl.style.width = `${size}px`;
          orbEl.style.height = `${size}px`;
          orbEl.style.left = `${orbX - cfg.radius}px`;
          orbEl.style.top = `${orbY - cfg.radius}px`;
        }

        // Reflow text around all active orbs
        layoutText(orbPositions, containerW);

        animFrameId = requestAnimationFrame(animate);
      }

      animFrameId = requestAnimationFrame(animate);
    }

    // Start after a short delay to let the page settle
    const timer = setTimeout(startAnimation, 2000);

    // Also start on hover if not started yet
    container.addEventListener('mouseenter', () => {
      clearTimeout(timer);
      startAnimation();
    }, { once: true });

    // Cleanup on navigation (Astro view transitions)
    document.addEventListener('astro:before-swap', () => {
      if (animFrameId) cancelAnimationFrame(animFrameId);
      clearTimeout(timer);
      running = false;
    });

    // Handle theme changes — update orb colors
    const observer = new MutationObserver(() => {
      for (let i = 0; i < orbConfigs.length; i++) {
        if (orbPositions[i].active && orbEls[i]) {
          orbEls[i].style.background = getOrbGradient(0.5);
        }
      }
    });
    observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
  }

  // Use async wrapper for dynamic import
  async function boot() {
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', () => initPretextAnimation());
    } else {
      setTimeout(() => initPretextAnimation(), 100);
    }
  }
  boot();
</script>
