---
import { getTranslation, type Lang } from '../i18n/index';

interface Props {
  lang?: Lang;
}

const { lang = 'en' } = Astro.props;
const t = getTranslation(lang);
const longText = t.hero.longText;
---

<div class="mb-8">
  <p class="text-lg font-bold mb-1 text-(--color-accent)">{t.hero.line1}</p>
  <p class="text-sm mb-6 text-(--color-text-dim)">{t.hero.line2}</p>
</div>

<div class="text-sm leading-relaxed whitespace-pre-line text-(--color-text-dim)">
  {longText}
</div>
