---
import { getLangs, getPathWithoutLocale, localizedPath, type Lang } from '../i18n/index';

interface Props {
  lang: Lang;
  currentPath?: string;
}

const { lang, currentPath } = Astro.props;
const langs = getLangs();
// Use explicit currentPath prop to avoid Astro.url issues on static builds
const rawPath = currentPath || Astro.url.pathname;
const basePath = getPathWithoutLocale(new URL(rawPath, 'https://nevrai.com'));
---
<div class="flex items-center gap-1 text-xs font-mono">
  {langs.map((l, i) => (
    <>
      <a
        href={localizedPath(l, basePath)}
        class:list={[
          'no-underline px-1 py-0.5 rounded transition-colors',
          l === lang
            ? 'text-(--color-accent) font-semibold'
            : 'text-(--color-text-dim) hover:text-(--color-accent)',
        ]}
      >
        {l.toUpperCase()}
      </a>
      {i < langs.length - 1 && <span class="text-(--color-text-dim) opacity-30">|</span>}
    </>
  ))}
</div>
