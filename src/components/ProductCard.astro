---
interface Props {
  name: string;
  tagline: string;
  lightTagline?: string;
  url?: string;
  status: 'LIVE' | 'LAUNCHING' | 'BUILDING' | 'PLANNED' | 'BUILT';
  stack?: string[];
  metric?: string;
  lightMetric?: string;
}

const { name, tagline, lightTagline, url, status, stack = [], metric, lightMetric } = Astro.props;

const badgeClass = {
  LIVE: 'badge-live',
  LAUNCHING: 'badge-launching',
  BUILDING: 'badge-building',
  PLANNED: 'badge-planned',
  BUILT: 'badge-built',
}[status];

const slug = name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/-+$/, '');
---
<div class="card border border-(--color-border) p-4 sm:p-5 hover:border-(--color-accent) transition-colors bg-(--color-bg-card) relative">
  <div class="flex items-start justify-between gap-2 mb-2">
    <h3 class="text-base font-semibold m-0 !text-inherit !normal-case !tracking-normal">
      <a href={`/products/${slug}`} class="no-underline text-(--color-text) hover:text-(--color-accent)">{name}</a>
    </h3>
    <div class="flex items-center gap-2">
      <button
        class="upvote-btn flex items-center gap-1 text-[0.65rem] text-(--color-text-dim) hover:text-(--color-accent) transition-colors cursor-pointer bg-transparent border-none p-0 font-mono"
        data-slug={slug}
        aria-label="Upvote"
      >
        <svg width="10" height="8" viewBox="0 0 10 8" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 1L9 7H1L5 1Z" />
        </svg>
        <span class="upvote-count">0</span>
      </button>
      <span class={`badge ${badgeClass}`}>{status}</span>
    </div>
  </div>
  {lightTagline ? (
    <p class="text-sm text-(--color-text-dim) mb-3 leading-relaxed">
      <span class="theme-dark">{tagline}</span>
      <span class="theme-light">{lightTagline}</span>
    </p>
  ) : (
    <p class="text-sm text-(--color-text-dim) mb-3 leading-relaxed">{tagline}</p>
  )}
  {stack.length > 0 && (
    <div class="flex flex-wrap gap-1.5 mb-2">
      {stack.map(tech => (
        <span class="text-[0.625rem] px-1.5 py-0.5 border border-(--color-border) rounded text-(--color-text-dim) font-mono">
          {tech}
        </span>
      ))}
    </div>
  )}
  {metric && (
    <p class="text-xs text-(--color-accent) mt-2 mb-0 font-mono">
      {lightMetric ? (
        <>
          <span class="theme-dark">{metric}</span>
          <span class="theme-light">{lightMetric}</span>
        </>
      ) : (
        metric
      )}
    </p>
  )}
</div>
